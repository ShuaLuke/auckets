# AUCKETS environment variables
#
# Copy to .env.local for local development and fill in the values.
# Never commit .env.local or any file containing real secrets.
#
# All variables are validated at build time by src/lib/env.ts (Zod).

# --- Database (Supabase Postgres) -------------------------------------------
# Connection string for your local or staging Supabase project.
# Use the "transaction" pooler URL for serverless; "session" for migrations.
DATABASE_URL=

# --- Public site config -----------------------------------------------------
# The URL the app is served from. Used in emails, OAuth callbacks, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Clerk authentication ---------------------------------------------------
# Get these from https://dashboard.clerk.com (your AUCKETS dev instance).
# The publishable key starts with `pk_test_` (dev) or `pk_live_` (prod).
# The secret key starts with `sk_test_` or `sk_live_`. NEVER commit it.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Inngest (optional locally) ---------------------------------------------
# Background jobs. Locally, `npm run inngest:dev` runs unauthenticated.
# Set these only when deploying to staging/prod.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Resend / email (optional) ----------------------------------------------
# Email sending. Without RESEND_API_KEY the email client stays dormant —
# sendEmail() logs a warning and returns without sending. Get the key from
# https://resend.com/api-keys (starts with `re_`).
RESEND_API_KEY=
# Default from address. Override per-send via the `from` arg.
RESEND_FROM_EMAIL=noreply@auckets.com

# --- Sentry (optional) ------------------------------------------------------
# DSN for error reporting. Leave empty to keep Sentry dormant.
# DSNs are intended to be public — exposing one only allows the
# referenced project to accept events.
NEXT_PUBLIC_SENTRY_DSN=

# --- Stripe (optional locally; required for the real /api/offers path) ------
# When unset, the Stripe client (src/lib/stripe/client.ts) stays dormant
# and POST /api/offers falls back to the dev stub (gated on
# ALLOW_DEV_OFFER_STUB). Same dormant-without-keys posture as Resend.
#
# Test mode keys (sk_test_, pk_test_, whsec_) for local dev + Vercel
# previews. Live keys (sk_live_, pk_live_) only on Vercel production.
# Get them from https://dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Card-failure recovery window in minutes (how long a failed-card seat is held
# for the fan to submit a new card). Optional — defaults to 240 (4h, ADR-0003
# / OPEN_QUESTION B). Read by /api/offers/[id]/recover + the expiry cron.
CARD_FAILURE_RECOVERY_WINDOW_MINUTES=

# --- Dev-only escape hatches ------------------------------------------------
# ALLOW_DEV_OFFER_STUB: set to "true" to enable the stub POST /api/offers
# endpoint that bypasses Stripe (placeholder IDs in the offer row). Lets
# you exercise the bid flow end-to-end before ADR-0003 (Stripe
# SetupIntent vs. pre-auth hold-window) is finalized. Refused in
# production at module load. Default "false".
ALLOW_DEV_OFFER_STUB=false
